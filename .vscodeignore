# --- VCS & editor metadata ---
.git/**
.gitignore
.gitattributes
.vscode/**
.vscode-test/**
.idea/**
.fleet/**
.claude/**

# --- OS / scratch files ---
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db

# --- Build / source-of-truth scripts (not needed at runtime) ---
build.py
build_previews.py
_clip_png.py
__pycache__/**
**/__pycache__/**
*.pyc
*.pyo

# --- Dev dependencies ---
node_modules/**
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Local config / secrets (defence in depth) ---
.env
.env.*
*.local
.secret
.secrets/**
*.pem
*.key

# --- Backup / temp ---
*.bak
*.swp
*.swo
*~
*.tmp

# --- Other extension artifacts ---
*.vsix

# --- Source-only assets ---
# Marketplace gets the PNG previews referenced by README;
# the SVG intermediates are regenerated by build_previews.py.
previews/*.svg
icon.svg
